{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Handoff Schema for QA Agents",
  "description": "Recibo minimo de validacion por transicion. El contenido de trabajo (requisitos, gaps, decisiones, etc.) vive en el markdown de resumen del agente, no en este JSON.",
  "type": "object",
  "additionalProperties": false,
  "required": ["handoff"],
  "properties": {
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent",
        "session_id",
        "timestamp",
        "correlation_id",
        "retry_count",
        "status",
        "assigned_task",
        "work_performed",
        "checks",
        "counts",
        "summary_md",
        "work_log_md"
      ],
      "properties": {
        "agent": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,30}$"
        },
        "session_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "correlation_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.[a-z][a-z0-9_]{2,30}\\.[0-3]$"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "status": {
          "type": "string",
          "enum": ["completed", "blocked", "partial"]
        },
        "assigned_task": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "scope_received"],
          "description": "Hechos que el agente reporta sobre el encargo recibido. El agente NUNCA autoevalua su cumplimiento; eso lo calcula el Orquestador comparando estos campos contra su propia instruccion original.",
          "properties": {
            "task_id": {
              "type": "string",
              "description": "Eco literal del identificador de instruccion emitido por el Orquestador."
            },
            "scope_received": {
              "type": "string",
              "description": "Eco textual de lo que el agente entendio que se le pedia."
            }
          }
        },
        "work_performed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sections_touched", "sections_untouched"],
          "description": "Hechos observables sobre que se modifico realmente, no una narrativa ni un juicio de cumplimiento.",
          "properties": {
            "sections_touched": {
              "type": "array",
              "items": { "type": "string" }
            },
            "sections_untouched": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "checks": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "summary_md": {
          "type": "string",
          "description": "Ruta al markdown de trabajo completo del agente (fuente de verdad del contenido)."
        },
        "work_log_md": {
          "type": "string",
          "description": "Ruta al log de ejecucion por paso del agente (auditoria interna, comentarios y bloqueos)."
        }
      }
    }
  }
}
