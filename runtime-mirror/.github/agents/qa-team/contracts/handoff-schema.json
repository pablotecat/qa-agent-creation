{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Handoff Schema for QA Agents",
  "type": "object",
  "additionalProperties": false,
  "required": ["handoff"],
  "properties": {
    "handoff": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "metadata",
        "context",
        "executive_summary",
        "artifacts_references",
        "delta_changes",
        "validation_checklist",
        "next_agent_instructions",
        "feedback_hooks"
      ],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "from_agent",
            "to_agent",
            "session_id",
            "timestamp",
            "retry_count",
            "correlation_id",
            "handoff_kind"
          ],
          "properties": {
            "from_agent": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{2,30}$"
            },
            "to_agent": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{2,30}$"
            },
            "session_id": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "retry_count": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            },
            "correlation_id": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.[a-z][a-z0-9_]{2,30}-to-[a-z][a-z0-9_]{2,30}\\.[0-3]$"
            },
            "handoff_kind": {
              "type": "string",
              "enum": ["full", "fragment"]
            }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "required": ["user_request_id", "phase", "status"],
          "properties": {
            "user_request_id": {
              "type": "string"
            },
            "phase": {
              "type": "string",
              "enum": ["planning_layer", "creation_layer", "execution_layer", "analysis_layer"]
            },
            "status": {
              "type": "string",
              "enum": ["ready_for_handoff", "escalated", "failed", "completed"]
            }
          }
        },
        "executive_summary": {
          "type": "object",
          "additionalProperties": true,
          "required": ["state_snapshot", "critical_findings", "recommendation"],
          "properties": {
            "state_snapshot": {
              "type": "string"
            },
            "critical_findings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "recommendation": {
              "type": "string"
            }
          }
        },
        "artifacts_references": {
          "type": "object",
          "additionalProperties": true,
          "required": ["path_pattern", "summary_md", "raw_data", "version_hash"],
          "properties": {
            "path_pattern": {
              "type": "string"
            },
            "summary_md": {
              "type": "string"
            },
            "raw_data": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            },
            "version_hash": {
              "type": "string"
            }
          }
        },
        "delta_changes": {
          "type": "object",
          "additionalProperties": true,
          "required": ["added", "modified", "removed", "updated_by", "rationale"],
          "properties": {
            "added": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "modified": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "removed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "updated_by": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{2,30}$"
            },
            "rationale": {
              "type": "string"
            }
          }
        },
        "validation_checklist": {
          "type": "object",
          "additionalProperties": true,
          "required": ["status", "checks"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["passed", "warning", "failed"]
            },
            "checks": {
              "type": "object",
              "additionalProperties": {
                "type": "boolean"
              }
            }
          }
        },
        "next_agent_instructions": {
          "type": "object",
          "additionalProperties": true,
          "required": ["must_validate", "can_skip", "decision_points"],
          "properties": {
            "must_validate": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "can_skip": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "decision_points": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "feedback_hooks": {
          "type": "object",
          "additionalProperties": true,
          "required": ["if_gaps_found", "if_coverage_impossible", "if_conflict_detected"],
          "properties": {
            "if_gaps_found": {
              "type": "object",
              "additionalProperties": true,
              "required": ["escalate_to"],
              "properties": {
                "escalate_to": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{2,30}$"
                }
              }
            },
            "if_coverage_impossible": {
              "type": "object",
              "additionalProperties": true,
              "required": ["escalate_to"],
              "properties": {
                "escalate_to": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{2,30}$"
                }
              }
            },
            "if_conflict_detected": {
              "type": "object",
              "additionalProperties": true,
              "required": ["escalate_to", "conflict_resolution_strategy"],
              "properties": {
                "escalate_to": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{2,30}$"
                },
                "conflict_resolution_strategy": {
                  "type": "string"
                }
              }
            }
          }
        },
        "fragment_context": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "source_handoff_correlation_id",
            "source_handoff_path",
            "included_sections",
            "omitted_sections",
            "consumer_notice",
            "request_full_context_when_needed"
          ],
          "properties": {
            "source_handoff_correlation_id": {
              "type": "string"
            },
            "source_handoff_path": {
              "type": "string"
            },
            "included_sections": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "omitted_sections": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "consumer_notice": {
              "type": "string"
            },
            "request_full_context_when_needed": {
              "type": "boolean"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "metadata": {
                "properties": {
                  "handoff_kind": {
                    "const": "fragment"
                  }
                },
                "required": ["handoff_kind"]
              }
            }
          },
          "then": {
            "required": ["fragment_context"]
          }
        }
      ]
    }
  }
}
