{
  "orchestration": {
    "mode": "sequential",
    "prerequisite_resolution_default": "pre_resolve",
    "max_attempts": 3,
    "persistence_required_before_routing": true,
    "session_folder_pattern": "session_{session_N}_{session_id}",
    "session_counter_file": "./tests/Documentation/handoffs/session-counter.json"
  },
  "validation": {
    "precedence_mode": "V1",
    "schema_blocking": true,
    "checklist_failed_blocking": true,
    "checklist_warning_allows_routing": true
  },
  "naming": {
    "handoff_filename_pattern": "{agent}-handoff-{timestamp}.json",
    "agent_summary_filename_by_role": {
      "test_documentation": "test_documentation-analysis-report.md",
      "orchestrator": "ORCHESTRATION_FINAL_SUMMARY.md"
    },
    "agent_work_log_filename_by_role": {
      "test_documentation": "test_documentation-work-log.md"
    },
    "agent_name_pattern": "^[a-z][a-z0-9_]{2,30}$",
    "correlation_id_pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.[a-z][a-z0-9_]{2,30}\\.[0-3]$"
  },
  "status_model": {
    "handoff_status": [
      "completed",
      "blocked",
      "partial"
    ],
    "session_status_global": [
      "in_progress",
      "completed",
      "completed_with_warnings",
      "blocked",
      "failed"
    ]
  },
  "agent_catalog": {
    "orchestrator": {
      "layer": "orchestration",
      "user_invocable": true,
      "path": ".github/agents/"
    },
    "test_documentation": {
      "layer": "planning_layer",
      "user_invocable": false,
      "path": ".github/agents/qa-team/"
    }
  },
  "transitions": {
    "default_entry_agent": {
      "full_pipeline": "test_documentation",
      "documentation_only": "test_documentation"
    },
    "allowed_handoffs": [
      "orchestrator-to-test_documentation",
      "test_documentation-to-orchestrator"
    ]
  },
  "escalation_policy": {
    "abort_on_retry_limit": true,
    "abort_status_global": "blocked"
  }
}
