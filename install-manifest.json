{
  "manifest_version": "2.0.0",
  "installer_mode": "mirror_recursive",
  "runtime_mirror_root": "./runtime-mirror/.github",
  "destination_root": ".github",
  "authority": "filesystem_mirror",
  "overwrite_policy": {
    "selection_mode": "interactive_global_per_run",
    "allowed_values": [
      "fail_if_exists",
      "overwrite",
      "skip_if_exists"
    ],
    "prompt_required": true,
    "default": null
  },
  "bootstrap_files_excluded_from_install": [
    "./install-prompt.md",
    "./install-manifest.json",
    "./README.md",
    "./ORCHESTRATION-RECOVERY.md"
  ]
}
