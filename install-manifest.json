{
  "manifest_version": "1.0.0",
  "installer_mode": "mirror_based",
  "runtime_mirror_root": "./runtime-mirror",
  "overwrite_policy": {
    "selection_mode": "interactive_global_per_run",
    "allowed_values": [
      "fail_if_exists",
      "overwrite",
      "skip_if_exists"
    ],
    "prompt_required": true,
    "default": null
  },
  "precedence": {
    "file_mapping_source_of_truth": "install-manifest.json",
    "installer_behavior_source_of_truth": "install-prompt.md",
    "on_conflict": "abort_with_error"
  },
  "entries": [
    {
      "id": "runtime-doc-agent",
      "source": "./runtime-mirror/.github/agents/documentation.QATesting.agent.md",
      "destination": ".github/agents/documentation.QATesting.agent.md",
      "classification": "runtime",
      "required": true
    },
    {
      "id": "runtime-planner-agent",
